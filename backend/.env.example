# ===== Server =====
APP_HOST=127.0.0.1
APP_PORT=8000
APP_CORS_ORIGINS=http://localhost:3000

# ===== Logging =====
# LOG_FILE 留空 → 写到 ${DATA_DIR}/logs/app.log
LOG_LEVEL=INFO
LOG_FILE=
LOG_MAX_BYTES=5000000
LOG_BACKUP_COUNT=5

# ===== Data dir (SQLite + Chroma + 导入文件) =====
DATA_DIR=./data

# ===== LLM (默认 profile,可在 UI 里再加多套) =====
# provider: anthropic | openai
LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=claude-sonnet-4-5-20250929
LLM_MAX_TOKENS=16384
LLM_TEMPERATURE=0.7

# ===== Embedding (用于向量库) =====
# provider: openai | anthropic | local (local = sentence-transformers,后续支持)
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small
